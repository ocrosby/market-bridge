# =============================================================================
# Market Bridge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for the platforms you use.
# You only need to configure the platforms you have accounts for.
#
#   cp .env.example .env
#
# =============================================================================


# -----------------------------------------------------------------------------
# Tradovate (Real-Time API — Primary Data Source)
# -----------------------------------------------------------------------------
# Required for: get_price_data, get_volume_profile, get_order_flow,
#               get_levels, get_heatmap (DOM), get_market_state
#
# To get these credentials:
# 1. Create an account at https://www.tradovate.com/
# 2. Log in to https://trader.tradovate.com/
# 3. Go to Settings > API Access > Request API Access (may take 1-2 days)
# 4. Once approved: API Access > Manage API Keys > + New API Key
# 5. Copy the Client ID (CID), Client Secret (SEC), and App ID
#
# See README.md "Platform Setup > Tradovate" for detailed instructions.
# -----------------------------------------------------------------------------

# Your Tradovate login username (the email or username you registered with)
TRADOVATE_USERNAME=

# Your Tradovate login password
TRADOVATE_PASSWORD=

# The name you gave your API application (e.g. "MarketBridge")
TRADOVATE_APP_ID=

# Version string — just use 1.0
TRADOVATE_APP_VERSION=1.0

# Client ID — numeric, shown after creating your API key
TRADOVATE_CID=0

# Client Secret — shown once after creating your API key (copy it immediately)
TRADOVATE_SEC=

# true = demo/simulation environment (delayed data, no real money)
# false = live environment (real-time data, real account)
# Start with true while testing, switch to false when ready
TRADOVATE_DEMO=true


# -----------------------------------------------------------------------------
# Bookmap (Heatmap & Volume Profile CSV Exports)
# -----------------------------------------------------------------------------
# Required for: get_heatmap (best quality), get_volume_profile (best quality)
#
# Bookmap does not have a live API. Market Bridge reads CSV files that you
# export from Bookmap manually.
#
# To set up:
# 1. Install Bookmap from https://bookmap.com/ (Digital plan or higher)
# 2. Connect it to a data feed (Tradovate, Rithmic, or CQG)
# 3. Open a chart > Tools > Export Heatmap Data > save to the directory below
#
# Expected file naming in the export directory:
#   *heatmap*.csv    — for heatmap data (e.g. ES_heatmap_20260418.csv)
#   *volume*.csv     — for volume profile data (e.g. ES_volume_profile.csv)
#
# See README.md "Platform Setup > Bookmap" for detailed instructions.
# -----------------------------------------------------------------------------

# Absolute path to the directory where Bookmap exports CSV files
# Default (if unset): $HOME/Documents/Bookmap/exports
BOOKMAP_EXPORT_DIR=/Users/yourname/Documents/Bookmap/exports


# -----------------------------------------------------------------------------
# Thinkorswim (CSV Export Fallback)
# -----------------------------------------------------------------------------
# Required for: get_price_data (fallback), get_volume_profile (fallback)
#
# Thinkorswim (TOS) by Charles Schwab exports chart data as CSV files.
# Market Bridge reads these as a fallback when Tradovate is not configured.
#
# To set up:
# 1. Open a Schwab account at https://www.schwab.com/trading/thinkorswim
# 2. Install thinkorswim desktop app and log in
# 3. Open a chart for /ES > Right-click > Export Chart Data > Export to CSV
# 4. Save with a descriptive name (e.g. ES_price.csv) to the directory below
#
# Tip: You can use TOS in paperMoney mode (simulated) — no need to fund
# the account.
#
# Expected file naming in the export directory:
#   *ES*price*.csv   — for /ES OHLCV data (e.g. ES_price.csv)
#   *NQ*price*.csv   — for /NQ OHLCV data
#   *ES*.csv         — fallback pattern if no *price* match
#
# See README.md "Platform Setup > Thinkorswim" for detailed instructions.
# -----------------------------------------------------------------------------

# Absolute path to the directory where TOS exports CSV files
# Default (if unset): $HOME/Documents/thinkorswim/exports
TOS_EXPORT_DIR=/Users/yourname/Documents/thinkorswim/exports


# -----------------------------------------------------------------------------
# Cache Settings (optional — defaults are usually fine)
# -----------------------------------------------------------------------------

# How many seconds to cache API responses before re-fetching (default: 30)
CACHE_DEFAULT_TTL=30

# Maximum number of cached entries before evicting the oldest (default: 500)
CACHE_MAX_ENTRIES=500
