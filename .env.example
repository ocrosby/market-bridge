# Tradovate API credentials (required for real-time data)
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=0
TRADOVATE_SEC=
TRADOVATE_DEMO=true

# Bookmap export directory (for heatmap/volume data)
BOOKMAP_EXPORT_DIR=~/Documents/Bookmap/exports

# Thinkorswim export directory (for CSV study exports)
TOS_EXPORT_DIR=~/Documents/thinkorswim/exports

# Cache settings
CACHE_DEFAULT_TTL=30
CACHE_MAX_ENTRIES=500
